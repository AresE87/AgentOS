# AgentOS Environment Variables
# Copy this file to .env and fill in your values

# === LLM Provider API Keys (at least one required) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=

# === Agent Configuration ===
AGENTOS_LOG_LEVEL=INFO
AGENTOS_MAX_COST_PER_TASK=1.00
AGENTOS_CLI_TIMEOUT=300
AGENTOS_DB_PATH=data/agentos.db
