{
  "id": "weather-check",
  "name": "Weather Check",
  "description": "Gets the current weather for a city using the wttr.in API",
  "category": "research",
  "version": "1.0.0",
  "author": "AgentOS",
  "tags": ["weather", "forecast", "city", "temperature"],
  "steps": [
    {
      "id": "step-1",
      "description": "Get weather for a city",
      "action_type": "shell",
      "command": "$city = 'London'; $encoded = [Uri]::EscapeDataString($city); Invoke-RestMethod \"https://wttr.in/$encoded?format=3\""
    }
  ],
  "created_at": "2025-01-01T00:00:00Z"
}
