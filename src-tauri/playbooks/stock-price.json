{
  "id": "stock-price",
  "name": "Stock Price",
  "description": "Fetches the current stock price for a given ticker symbol",
  "category": "research",
  "version": "1.0.0",
  "author": "AgentOS",
  "tags": ["stock", "finance", "price", "market"],
  "steps": [
    {
      "id": "step-1",
      "description": "Get stock price via Yahoo Finance API",
      "action_type": "shell",
      "command": "$ticker = 'AAPL'; $response = Invoke-RestMethod \"https://query1.finance.yahoo.com/v8/finance/chart/$ticker?interval=1d&range=1d\"; $price = $response.chart.result[0].meta.regularMarketPrice; $currency = $response.chart.result[0].meta.currency; Write-Output \"$ticker: $price $currency\""
    }
  ],
  "created_at": "2025-01-01T00:00:00Z"
}
